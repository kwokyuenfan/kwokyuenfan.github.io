{% comment %}
  Local override of al_folio_cv experience.liquid.
  Fixes:
  - Empty location row no longer renders an orphan icon (strip whitespace from capture).
  - Year badge and location marker share the same horizontal anchor so they line up.
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    {% assign start_raw = entry.start_date | default: entry.startDate %}
    {% assign end_raw = entry.end_date | default: entry.endDate %}
    {% if start_raw %}
      {% assign startDate = start_raw | split: '-' | first %}
      {% assign endDate = end_raw | split: '-' | first | default: 'Present' %}
      {% assign date = startDate | append: ' - ' | append: endDate %}
    {% else %}
      {% assign date = '' %}
    {% endif %}

    {% assign location = entry.location | default: '' | strip %}

    <li class="list-group-item">
      <div class="row">
        <div class="col-xs-2 col-sm-2 col-md-2 text-center date-column">
          <div style="display: inline-block; text-align: left;">
            {% if date != '' %}
              <span
                class="badge font-weight-bold danger-color-dark text-uppercase align-middle"
                style="min-width: 75px; display: inline-block; text-align: center;"
              >
                {{- date -}}
              </span>
            {% endif %}
            {% if location != '' %}
              <p class="location" style="margin: 0.3rem 0 0 0; text-align: left;">
                <i class="fa-solid fa-location-dot iconlocation"></i>
                {{ location }}
              </p>
            {% endif %}
          </div>
        </div>
        <div class="col-xs-10 col-sm-10 col-md-10 mt-2 mt-md-0">
          {% assign position_title = entry.position | default: '' %}
          {% if entry.url and position_title != '' %}
            <h6 class="title font-weight-bold ml-1 ml-md-4">
              <a href="{{ entry.url }}">{{ position_title }}</a>
            </h6>
          {% elsif position_title != '' %}
            <h6 class="title font-weight-bold ml-1 ml-md-4">{{ position_title }}</h6>
          {% endif %}

          {% assign company_name = entry.name | default: entry.company | default: entry.organization %}
          {% if company_name %}
            <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem">{{ company_name }}</h6>
          {% endif %}

          {% if entry.summary %}
            <h6 class="ml-1 ml-md-4" style="font-size: 0.95rem; font-style: italic">
              {{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}
            </h6>
          {% endif %}

          {% if entry.highlights %}
            <ul class="items">
              {% for item in entry.highlights %}
                <li>
                  <span class="item">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      </div>
    </li>
  {% endfor %}
</ul>
